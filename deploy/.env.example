# Web platform environment. Copy to deploy/.env and fill in. Never commit deploy/.env.

# --- LLM (script brain) + COST CAP ($3 of MiniMax credit) ---
LLM_API_KEY=                              # required
LLM_BASE_URL=https://api.minimax.io/v1
LLM_MODEL=MiniMax-M3
LLM_MAX_COST_USD=3.0                      # HARD spend ceiling, enforced at enqueue + mid-run
# MiniMax-M3 USD per 1K tokens (adjust to real pricing so the gate is accurate).
LLM_PRICE_IN_PER_1K=0.0003
LLM_PRICE_OUT_PER_1K=0.0011

# --- GPU box gRPC inference (reached over WireGuard/SSH from this EC2) ---
# DEFAULT = on-demand pools via gpud (scale-to-zero): the worker leases an ASR/TTS instance
# per task; gpud launches it on a free GPU and reaps it when idle. The tunnel/sidecar forwards
# gpud (50050) + the instance range (GPUD_PORT_RANGE, default 50060-50099).
GPU_SUPERVISOR_TARGET=10.10.0.2:50050
# Always-on fallback — ONLY if you disable gpud: unset GPU_SUPERVISOR_TARGET above and
# uncomment these to point at hand-run asr/tts servers.
# ASR_GRPC_TARGET=10.10.0.2:50051
# TTS_GRPC_TARGET=10.10.0.2:50052

# --- storage (S3) ---
STORAGE_BACKEND=s3
S3_BUCKET=jieshuo-artifacts
AWS_REGION=us-east-1
# Prefer an EC2 IAM instance role over static keys. If you must use keys, set:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# S3_ENDPOINT_URL=                        # internal endpoint for MinIO/non-AWS S3 (unset = AWS)
# S3_PUBLIC_ENDPOINT_URL=                 # browser-reachable endpoint for presigned URLs (MinIO local)

# --- infra (compose service names) ---
DATABASE_URL=postgresql+psycopg://jieshuo:jieshuo@postgres:5432/jieshuo
REDIS_URL=redis://redis:6379/0
POSTGRES_PASSWORD=jieshuo
WORK_ROOT=/scratch/work
PUSHGATEWAY_URL=http://pushgateway:9091   # worker per-run metrics (optional)

# --- sessions (no sign-in) ---
SESSION_SECRET=change-me-to-a-long-random-string
COOKIE_SECURE=true                        # set false for local http testing
SESSION_MAX_AGE=31536000                  # 1 year

# --- quotas (protect the budget) ---
MAX_MOVIES_PER_SESSION=5
MAX_CONCURRENT_RUNS=2

# --- pipeline ---
PIPELINE_CONFIG=/app/config/pipeline.toml
