# PRODUCTION profile — AWS S3 for files. Used by docker-compose.prod.yml.
# Real secrets must come from the environment / a secrets manager, NOT this file.
# Values left blank here are injected at deploy time.

# --- LLM + cost cap ---
LLM_API_KEY=
LLM_BASE_URL=https://api.minimax.io/v1
LLM_MODEL=MiniMax-M3
LLM_MAX_COST_USD=3.0

# --- GPU box gRPC inference, reached via the in-cluster autossh tunnel ---
# DEFAULT = on-demand pools via gpud (scale-to-zero): the worker leases an ASR/TTS instance
# per task. The autossh sidecar forwards gpud (50050) + the instance range (GPUD_PORT_RANGE);
# leased targets resolve as gpu-tunnel:<port>.
GPU_SUPERVISOR_TARGET=gpu-tunnel:50050
# Always-on fallback — ONLY if you disable gpud: unset GPU_SUPERVISOR_TARGET above and
# uncomment these to point at hand-run asr/tts servers.
# ASR_GRPC_TARGET=gpu-tunnel:50051
# TTS_GRPC_TARGET=gpu-tunnel:50052
GPUD_HEARTBEAT_SEC=30
GPUD_ACQUIRE_TIMEOUT_SEC=180

# --- storage: AWS S3 (no endpoint override; prefer an EC2 IAM role over keys) ---
STORAGE_BACKEND=s3
S3_BUCKET=jieshuo-artifacts-prod
AWS_REGION=us-east-1
# S3_ENDPOINT_URL / S3_PUBLIC_ENDPOINT_URL: leave UNSET for real AWS S3.
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY: prefer instance role; set only if required.

# --- infra ---
DATABASE_URL=postgresql+psycopg://jieshuo:CHANGE_ME@postgres:5432/jieshuo
REDIS_URL=redis://redis:6379/0
POSTGRES_PASSWORD=CHANGE_ME
WORK_ROOT=/scratch/work
PUSHGATEWAY_URL=http://pushgateway:9091

# --- sessions (https: secure cookie) ---
SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
COOKIE_SECURE=true
SESSION_MAX_AGE=31536000

# --- quotas ---
MAX_MOVIES_PER_SESSION=0   # 0 = unlimited (no per-session movie cap)
MAX_CONCURRENT_RUNS=2
UPLOAD_URL_TTL=14400       # presigned-PUT lifetime (s); 4h so big videos over cellular don't expire
PIPELINE_CONFIG=/app/config/pipeline.toml
